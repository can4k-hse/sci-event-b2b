# Database
POSTGRES_USER=scievent
POSTGRES_PASSWORD=scievent
POSTGRES_DB=scievent
DATABASE_URL=postgresql+asyncpg://scievent:scievent@db:5432/scievent

# JWT
JWT_SECRET_KEY=dev-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP
OTP_EXPIRE_MINUTES=5
OTP_RATE_LIMIT_COUNT=5
OTP_RATE_LIMIT_WINDOW_MINUTES=10

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006"]
